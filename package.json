{
	"name": "repo",
	"private": true,
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		]
	},
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"matool:prepare": "pnpm -F @repo/scripts matool:prepare",
		"matool:map": "pnpm -F @repo/scripts matool:map",
		"import:matool": "pnpm -F @repo/scripts import:matool",
		"demo:seed-school": "pnpm -F @repo/scripts demo:seed-school",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"db:push": "turbo -F @repo/db db:push",
		"db:studio": "turbo -F @repo/db db:studio",
		"db:generate": "turbo -F @repo/db db:generate",
		"db:migrate": "turbo -F @repo/db db:migrate"
	},
	"dependencies": {
		"dotenv": "catalog:",
		"pg": "^8.20.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^25.6.0",
		"turbo": "^2.9.6"
	},
	"pnpm": {
		"overrides": {
			"@better-auth/sso": "1.6.5",
			"better-call": "1.3.5",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3"
		}
	},
	"packageManager": "pnpm@10.25.0"
}
